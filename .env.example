# Copy this file to .env and fill in real values.

# --- Application ---
APP_NAME="Gym Equipment API"
DEBUG=false

# --- Database (PostgreSQL) ---
# Sync URL is used by Alembic; async URL is used by the app (asyncpg driver).
# Host port 5433 maps to the compose Postgres container (avoids a native 5432).
DATABASE_URL=postgresql://gym:gym@localhost:5433/gym_equipment
ASYNC_DATABASE_URL=postgresql+asyncpg://gym:gym@localhost:5433/gym_equipment

# --- Security / JWT ---
# Generate a long random value, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- First admin (seeded on first run) ---
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-me

# --- Redis (equipment list caching) ---
REDIS_URL=redis://localhost:6379/0
